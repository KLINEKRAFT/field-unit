# AI provider configuration (all optional — the app works fully without AI).
# Never commit real keys. Set these in Vercel project settings for production.

# Which provider the AI routes should use: "anthropic" | "openai"
AI_PROVIDER=anthropic

# Anthropic (used for note actions: summarize, title, action items, tags, ...)
ANTHROPIC_API_KEY=

# Model override (optional)
AI_MODEL=

# OpenAI (used for Whisper transcription if configured, or as chat provider)
OPENAI_API_KEY=
